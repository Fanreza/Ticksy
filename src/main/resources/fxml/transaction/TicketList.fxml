<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ticksy.controller.transaction.TicketListController"
      spacing="16" styleClass="content-area">
    <Label fx:id="pageTitle" text="Tickets" styleClass="page-title"/>
    <HBox styleClass="toolbar-section" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search tickets..." styleClass="search-field"/>
        <Button text="Search" onAction="#onSearch" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ New Ticket" onAction="#onAdd" styleClass="btn-primary"/>
        <Button fx:id="btnEdit" text="Edit" onAction="#onEdit" styleClass="btn-secondary"/>
        <Button fx:id="btnClose" text="Close Ticket" onAction="#onClose" styleClass="btn-success"/>
        <Button fx:id="btnDelete" text="Delete" onAction="#onDelete" styleClass="btn-danger"/>
    </HBox>
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTicketNo" text="Ticket #" prefWidth="110"/>
                <TableColumn fx:id="colTitle" text="Title" prefWidth="220"/>
                <TableColumn fx:id="colCategory" text="Category" prefWidth="120"/>
                <TableColumn fx:id="colPriority" text="Priority" prefWidth="90"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                <TableColumn fx:id="colCreatedBy" text="Created By" prefWidth="130"/>
                <TableColumn fx:id="colAssignedTo" text="Assigned To" prefWidth="130"/>
                <TableColumn fx:id="colCreatedAt" text="Created" prefWidth="130"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
