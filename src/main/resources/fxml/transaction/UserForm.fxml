<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ticksy.controller.transaction.UserFormController"
      spacing="16" styleClass="content-area" alignment="TOP_CENTER">
    <Label fx:id="formTitle" text="Add User" styleClass="page-title"/>
    <VBox styleClass="form-container" spacing="16" maxWidth="550">
        <VBox spacing="4">
            <Label text="Username" styleClass="form-label"/>
            <TextField fx:id="usernameField" styleClass="form-field" promptText="Enter username"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Password" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" styleClass="form-field" promptText="Enter password"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Full Name" styleClass="form-label"/>
            <TextField fx:id="fullNameField" styleClass="form-field" promptText="Enter full name"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="emailField" styleClass="form-field" promptText="Enter email"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Phone" styleClass="form-label"/>
            <TextField fx:id="phoneField" styleClass="form-field" promptText="Enter phone"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Role" styleClass="form-label"/>
            <ComboBox fx:id="roleCombo" styleClass="form-field" maxWidth="Infinity"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Department" styleClass="form-label"/>
            <ComboBox fx:id="departmentCombo" styleClass="form-field" maxWidth="Infinity"/>
        </VBox>
        <VBox spacing="4">
            <CheckBox fx:id="activeCheck" text="Active" selected="true"/>
        </VBox>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <padding><Insets top="12"/></padding>
            <Button text="Cancel" onAction="#onCancel" styleClass="btn-secondary"/>
            <Button text="Save" onAction="#onSave" styleClass="btn-primary"/>
        </HBox>
    </VBox>
</VBox>
