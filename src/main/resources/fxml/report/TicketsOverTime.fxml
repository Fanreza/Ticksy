<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ticksy.controller.report.TicketsOverTimeController"
      spacing="16" styleClass="content-area">
    <Label text="Tickets Created Over Time" styleClass="page-title"/>
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colDate" text="Date" prefWidth="300"/>
                <TableColumn fx:id="colCount" text="Tickets Created" prefWidth="250"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
