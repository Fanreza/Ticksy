<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ticksy.controller.dashboard.DashboardController"
      spacing="24" styleClass="content-area">

    <Label text="Dashboard" styleClass="page-title"/>

    <!-- Stat Cards Row -->
    <HBox fx:id="statsRow" spacing="20">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTotalTickets" text="0" styleClass="stat-value"/>
            <Label text="Total Tickets" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblOpenTickets" text="0" styleClass="stat-value"/>
            <Label text="Open" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblInProgressTickets" text="0" styleClass="stat-value"/>
            <Label text="In Progress" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblResolvedTickets" text="0" styleClass="stat-value"/>
            <Label text="Resolved" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblClosedTickets" text="0" styleClass="stat-value"/>
            <Label text="Closed" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <!-- Recent Tickets Table -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <Label text="Recent Tickets" styleClass="card-header"/>
        <TableView fx:id="recentTicketsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTicketNo" text="Ticket #" prefWidth="120"/>
                <TableColumn fx:id="colTitle" text="Title" prefWidth="300"/>
                <TableColumn fx:id="colPriority" text="Priority" prefWidth="100"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                <TableColumn fx:id="colAssignee" text="Assignee" prefWidth="160"/>
                <TableColumn fx:id="colCreatedAt" text="Created" prefWidth="150"/>
            </columns>
        </TableView>
    </VBox>

</VBox>
