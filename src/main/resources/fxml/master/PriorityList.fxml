<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ticksy.controller.master.PriorityListController"
      spacing="16" styleClass="content-area">
    <Label text="Priorities" styleClass="page-title"/>
    <HBox styleClass="toolbar-section" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search priorities..." styleClass="search-field"/>
        <Button text="Search" onAction="#onSearch" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add" onAction="#onAdd" styleClass="btn-primary"/>
        <Button text="Edit" onAction="#onEdit" styleClass="btn-secondary"/>
        <Button text="Delete" onAction="#onDelete" styleClass="btn-danger"/>
    </HBox>
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="200"/>
                <TableColumn fx:id="colLevel" text="Level" prefWidth="100"/>
                <TableColumn fx:id="colColor" text="Color" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
