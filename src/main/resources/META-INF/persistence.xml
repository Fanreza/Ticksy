<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="ticksy-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.ticksy.model.Role</class>
        <class>com.ticksy.model.Department</class>
        <class>com.ticksy.model.Category</class>
        <class>com.ticksy.model.Priority</class>
        <class>com.ticksy.model.Status</class>
        <class>com.ticksy.model.User</class>
        <class>com.ticksy.model.Ticket</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver"   value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:postgresql://localhost:5432/ticksy"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="123qweasd"/>

            <property name="hibernate.dialect"       value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto"  value="update"/>
            <property name="hibernate.show_sql"      value="false"/>
            <property name="hibernate.format_sql"    value="true"/>

            <property name="hibernate.hikari.minimumIdle"  value="2"/>
            <property name="hibernate.hikari.maximumPoolSize" value="10"/>
        </properties>
    </persistence-unit>
</persistence>
